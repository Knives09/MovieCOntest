{
    "name": "mashfrog/movie-challenge",
    "description": "MovieChallenge — MySQL vs Neo4j Challenge Platform for Teams",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "laudis/neo4j-php-client": "^3.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "MovieChallenge\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
